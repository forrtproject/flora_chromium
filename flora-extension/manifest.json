{
  "manifest_version": 3,
  "name": "FLoRA — Replication Tracker",
  "version": "0.1.0",
  "description": "Surfaces replication and reproduction data from the FLoRA database on academic article pages and Google Scholar.",
  "minimum_chrome_version": "116",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://rep-api.forrt.org/*",
    "https://api.openalex.org/*",
    "https://api.crossref.org/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "*://scholar.google.com/*",
        "*://scholar.google.co.uk/*",
        "*://scholar.google.co.in/*",
        "*://scholar.google.co.jp/*",
        "*://scholar.google.co.kr/*",
        "*://scholar.google.co.za/*",
        "*://scholar.google.co.id/*",
        "*://scholar.google.co.th/*",
        "*://scholar.google.co.il/*",
        "*://scholar.google.ca/*",
        "*://scholar.google.de/*",
        "*://scholar.google.fr/*",
        "*://scholar.google.es/*",
        "*://scholar.google.it/*",
        "*://scholar.google.com.br/*",
        "*://scholar.google.com.au/*"
      ],
      "js": ["dist/content-general.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://scholar.google.com/*",
        "*://scholar.google.co.uk/*",
        "*://scholar.google.co.in/*",
        "*://scholar.google.co.jp/*",
        "*://scholar.google.co.kr/*",
        "*://scholar.google.co.za/*",
        "*://scholar.google.co.id/*",
        "*://scholar.google.co.th/*",
        "*://scholar.google.co.il/*",
        "*://scholar.google.ca/*",
        "*://scholar.google.de/*",
        "*://scholar.google.fr/*",
        "*://scholar.google.es/*",
        "*://scholar.google.it/*",
        "*://scholar.google.com.br/*",
        "*://scholar.google.com.au/*"
      ],
      "js": ["dist/content-scholar.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "dist/options.html",
    "open_in_tab": true
  }
}
